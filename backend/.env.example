# ===== Backend - Mais Horas =====

# Porta do servidor
PORT=3000

# String de conexão PostgreSQL
# Local (Docker compose deste repo): porta 5433 no host
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mais_horas

# Em produção (Render) defina PGSSL=true (ou NODE_ENV=production)
PGSSL=false

# Secret usada para assinar JWT (obrigatória)
JWT_SECRET=troque-isto-por-uma-string-aleatoria-longa

# URL pública da API
APP_URL=http://localhost:3000

# URL pública do frontend (usada no QR Code de verificação dos certificados)
WEB_URL=http://localhost:5173

# Origens permitidas no CORS (separadas por vírgula). Vazio = libera todas (use só em dev)
# CORS_ORIGIN=https://mais-horas-web.onrender.com
